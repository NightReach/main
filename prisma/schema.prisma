generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("ADVERTISER") // "ADVERTISER" or "PUBLISHER"
  name      String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offers   Offer[]
  domains  Domain[]
  clicks   Click[]
}


model Offer {
  id           Int     @id @default(autoincrement())
  title        String
  payout       Float
  advertiserId Int
  landingUrl   String?

  advertiser User @relation(fields: [advertiserId], references: [id])

  clicks      Click[]
  conversions Conversion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Domain {
  id          Int    @id @default(autoincrement())
  domain      String
  publisherId Int

  publisher User    @relation(fields: [publisherId], references: [id])
  clicks    Click[]
}

model Click {
  id      Int     @id @default(autoincrement())
  clickId String? @unique
  offer   Offer   @relation(fields: [offerId], references: [id])
  offerId Int

  publisher   User @relation(fields: [publisherId], references: [id])
  publisherId Int

  ipAddress String?
  userAgent String?
  subid     String?
  source    String?
  createdAt DateTime @default(now())

  Domain   Domain? @relation(fields: [domainId], references: [id])
  domainId Int?

  Conversion Conversion[]
}

model Conversion {
  id        Int      @id @default(autoincrement())
  clickId   String?
  offerId   Int
  payout    Decimal  @default(0)
  createdAt DateTime @default(now())

  click     Click?   @relation(fields: [clickId], references: [clickId])
  offer     Offer    @relation(fields: [offerId], references: [id])
}

